<div class="throw-dialog-body">
  <p class="base-throw">
    {{localize "ACKS-HENCHMEN.throwUi.base"}}: <strong>{{formula}}</strong>
    {{#if secret}}<span class="secret-badge" data-tooltip="{{localize 'ACKS-HENCHMEN.throwUi.secretHint'}}"><i class="fas fa-user-secret"></i> {{localize "ACKS-HENCHMEN.throwUi.secret"}}</span>{{/if}}
  </p>
  {{#if infoText}}<p class="throw-info hint">{{infoText}}</p>{{/if}}

  {{#each modifiers}}
  <div class="form-group modifier {{#if locked}}locked{{/if}}" {{#if sourceTooltip}}data-tooltip="{{sourceTooltip}}"{{/if}}>
    <label for="mod-{{id}}">{{labelText}}{{#if hintText}} <span class="hint">({{hintText}})</span>{{/if}}</label>
    {{#if isCheckbox}}
      <span class="mod-value">{{#if (gte value 0)}}+{{/if}}{{value}}</span>
      <input id="mod-{{id}}" type="checkbox" name="mod.{{id}}" {{#if initial}}checked{{/if}} {{#if locked}}disabled data-locked{{/if}} />
    {{/if}}
    {{#if isStepper}}
      <span class="mod-value">{{#if (gte valuePerStep 0)}}+{{/if}}{{valuePerStep}}/step</span>
      <input id="mod-{{id}}" type="number" name="mod.{{id}}" value="{{initial}}" step="1" min="{{min}}" max="{{max}}" {{#if locked}}disabled data-locked{{/if}} />
    {{/if}}
    {{#if isSelect}}
      <select id="mod-{{id}}" name="mod.{{id}}" {{#if locked}}disabled data-locked{{/if}}>
        {{#each options}}
        <option value="{{value}}" {{#if selected}}selected{{/if}} {{#if disabled}}disabled{{/if}}>{{labelText}} ({{#if (gte value 0)}}+{{/if}}{{value}})</option>
        {{/each}}
      </select>
    {{/if}}
  </div>
  {{/each}}

  <div class="form-group modifier misc">
    <label for="mod-misc">{{localize "ACKS-HENCHMEN.throwUi.misc"}}</label>
    <input id="mod-misc" type="number" name="mod.misc" value="0" step="1" />
  </div>

  <hr />
  <div class="throw-total">
    {{localize "ACKS-HENCHMEN.throwUi.totalModifier"}}: <strong data-throw-total>{{total}}</strong>
    <a class="gm-unlock" data-action="unlockAuto" data-tooltip="{{localize 'ACKS-HENCHMEN.throwUi.unlockAuto'}}"><i class="fas fa-unlock"></i></a>
  </div>

  <footer class="form-footer">
    <button type="submit"><i class="fas fa-dice"></i> {{localize "ACKS-HENCHMEN.throwUi.roll"}}</button>
  </footer>
</div>
