<div class="location-sheet-body">
  <header class="location-header">
    <img class="profile" src="{{actor.img}}" data-edit="img" alt="{{actor.name}}" />
    <div class="header-fields">
      <input class="location-name" name="name" type="text" value="{{actor.name}}" placeholder="{{localize 'ACKS-HENCHMEN.location.name'}}" />
      <div class="market-class-line">
        <span class="market-class-badge" data-tooltip="{{marketClassSource}}">
          {{localize "ACKS-HENCHMEN.location.marketClass"}}: <strong>{{marketClassRoman}}</strong>
        </span>
        {{#if searchFeeFormula}}
        <span class="market-class-badge" data-tooltip="{{localize 'ACKS-HENCHMEN.location.searchFeeHint'}}">
          {{localize "ACKS-HENCHMEN.location.searchFee"}}: <strong>{{searchFeeFormula}}</strong> gp/{{localize "ACKS-HENCHMEN.location.perWeek"}}
        </span>
        {{/if}}
        {{#if isGM}}
        <button type="button" data-action="processNow" data-tooltip="{{localize 'ACKS-HENCHMEN.location.processNowHint'}}">
          <i class="fas fa-rotate"></i> {{localize "ACKS-HENCHMEN.location.processNow"}}
        </button>
        <button type="button" data-action="advanceWeek" data-tooltip="{{localize 'ACKS-HENCHMEN.location.advanceWeekHint'}}">
          <i class="fas fa-forward"></i> {{localize "ACKS-HENCHMEN.location.advanceWeek"}}
        </button>
        {{/if}}
      </div>
    </div>
  </header>

  <nav class="tabs sheet-tabs" data-group="primary">
    {{#each tabs}}
    <a class="{{this.cssClass}}" data-action="tab" data-group="primary" data-tab="{{this.id}}"><i class="{{this.icon}}"></i> {{this.label}}</a>
    {{/each}}
  </nav>

  {{!-- ------------------------- Recruitment ------------------------- --}}
  <section class="tab location-tab {{tabs.recruitment.cssClass}}" data-group="primary" data-tab="recruitment">
    <details class="section" open>
      <summary>
        {{localize "ACKS-HENCHMEN.location.postings"}} ({{postings.length}})
        <button type="button" class="inline-add" data-action="createPosting"><i class="fas fa-plus"></i> {{localize "ACKS-HENCHMEN.posting.create"}}</button>
      </summary>
      {{#if postings.length}}
      <table class="postings-table">
        <thead>
          <tr>
            <th>{{localize "ACKS-HENCHMEN.posting.spec"}}</th>
            <th>{{localize "ACKS-HENCHMEN.posting.employer"}}</th>
            <th>{{localize "ACKS-HENCHMEN.posting.fees"}}</th>
            <th>{{localize "ACKS-HENCHMEN.posting.statusHeader"}}</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {{#each postings}}
          <tr data-posting-id="{{id}}" class="{{#unless isActive}}inactive{{/unless}}{{#if advertVeteran}} advert-veteran{{/if}}">
            <td data-tooltip="{{rollDetail}}">{{specLabel}}{{#if advertVeteran}} <i class="fas fa-bullhorn" data-tooltip="{{localize 'ACKS-HENCHMEN.posting.advertVeteranHint'}}"></i>{{/if}}{{#if isPrivate}} <i class="fas fa-user-lock" data-tooltip="{{localize 'ACKS-HENCHMEN.posting.privateHint'}}"></i>{{/if}}{{#if commissioned}} <i class="fas fa-scroll" data-tooltip="{{localize 'ACKS-HENCHMEN.posting.commissioned'}}"></i>{{/if}}{{#if liedLevel}} <i class="fas fa-mask" data-tooltip="{{localize 'ACKS-HENCHMEN.posting.liedLevel'}} {{liedLevel}}"></i>{{/if}}</td>
            <td>{{employerName}}</td>
            <td>{{feesTotal}} gp</td>
            <td>{{statusLabel}}</td>
            <td class="row-actions">
              {{#if @root.isGM}}
              <a data-action="togglePlayerDetails" data-tooltip="{{localize 'ACKS-HENCHMEN.posting.toggleDetails'}}"><i class="fas {{#if playersSeeDetails}}fa-eye{{else}}fa-eye-slash{{/if}}"></i></a>
              {{/if}}
              {{#if isActive}}{{#if isMine}}
              <a data-action="closePosting" data-tooltip="{{localize 'ACKS-HENCHMEN.posting.close'}}"><i class="fas fa-xmark"></i></a>
              {{/if}}{{/if}}
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
      {{else}}
      <p class="hint">{{localize "ACKS-HENCHMEN.posting.none"}}</p>
      {{/if}}
    </details>

    <details class="section" open>
      <summary>{{localize "ACKS-HENCHMEN.special.header"}} ({{specialHires.length}}{{#if directedRows.length}} + {{directedRows.length}}{{/if}})</summary>
      <p class="hint">{{localize "ACKS-HENCHMEN.special.hint"}}</p>
      {{#if directedRows.length}}
      <h4 class="bucket-header">{{localize "ACKS-HENCHMEN.special.directed"}} ({{directedRows.length}})</h4>
      <table class="candidates-table">
        <thead>
          <tr>
            <th>{{localize "ACKS-HENCHMEN.candidate.name"}}</th>
            <th>{{localize "ACKS-HENCHMEN.candidate.age"}}</th>
            <th>{{localize "ACKS-HENCHMEN.candidate.culture"}}</th>
            <th>{{localize "ACKS-HENCHMEN.candidate.identity"}}</th>
            <th>{{localize "ACKS-HENCHMEN.candidate.wage"}}</th>
            <th>{{localize "ACKS-HENCHMEN.special.refusals"}}</th>
            <th>{{localize "ACKS-HENCHMEN.candidate.statusHeader"}}</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {{#each directedRows}}
          <tr data-candidate-id="{{id}}" class="status-{{status}}">
            <td data-tooltip="{{appearanceTip}}">{{name}} <i class="fas fa-user-lock" data-tooltip="{{localize 'ACKS-HENCHMEN.posting.privateHint'}}"></i></td>
            <td>{{age}}</td>
            <td>{{cultureLabel}}</td>
            <td>{{identityLine}}</td>
            <td>{{#if wageGp}}{{wageGp}} gp/{{wageUnit}}{{/if}}</td>
            <td>{{refusalCount}}</td>
            <td>{{statusLabel}}</td>
            <td class="row-actions">
              {{#if isAvailable}}
              <a data-action="recruit" data-tooltip="{{localize 'ACKS-HENCHMEN.candidate.recruit'}}"><i class="fas fa-handshake"></i></a>
              {{/if}}
              {{#if @root.isGM}}
              <a data-action="removeCandidate" data-tooltip="{{localize 'ACKS-HENCHMEN.candidate.remove'}}"><i class="fas fa-trash"></i></a>
              {{/if}}
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
      {{/if}}
      {{#if specialHires.length}}
      <h4 class="bucket-header">{{localize "ACKS-HENCHMEN.special.actors"}} ({{specialHires.length}})</h4>
      <table class="candidates-table">
        <thead>
          <tr>
            <th>{{localize "ACKS-HENCHMEN.candidate.name"}}</th>
            <th>{{localize "ACKS-HENCHMEN.special.origin.header"}}</th>
            <th>{{localize "ACKS-HENCHMEN.special.limit"}}</th>
            <th>{{localize "ACKS-HENCHMEN.special.refusals"}}</th>
            <th>{{localize "ACKS-HENCHMEN.candidate.statusHeader"}}</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          {{#each specialHires}}
          <tr data-special-id="{{id}}" class="status-{{status}}">
            <td><img class="special-portrait" src="{{img}}" alt="" /> {{name}}</td>
            <td>{{originLabel}}</td>
            <td>{{limitLabel}}</td>
            <td>{{refusalCount}}</td>
            <td>{{statusLabel}}</td>
            <td class="row-actions">
              {{#if isAvailable}}
              <a data-action="recruitSpecial" data-tooltip="{{localize 'ACKS-HENCHMEN.candidate.recruit'}}"><i class="fas fa-handshake"></i></a>
              {{/if}}
              {{#if @root.isGM}}
              <a data-action="setSpecialLimit" data-tooltip="{{localize 'ACKS-HENCHMEN.special.setLimit'}}"><i class="fas fa-hourglass-half"></i></a>
              <a data-action="removeSpecial" data-tooltip="{{localize 'ACKS-HENCHMEN.candidate.remove'}}"><i class="fas fa-trash"></i></a>
              {{/if}}
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
      {{/if}}
      {{#unless specialHires.length}}{{#unless directedRows.length}}
      <p class="hint">{{localize "ACKS-HENCHMEN.special.empty"}}</p>
      {{/unless}}{{/unless}}
    </details>
  </section>

  {{!-- ------------------------- Henchmen ------------------------- --}}
  <section class="tab location-tab {{tabs.henchmen.cssClass}}" data-group="primary" data-tab="henchmen">
    {{#if henchmenRows.length}}
    <div class="candidate-filter">
      <i class="fas fa-magnifying-glass"></i>
      <input type="text" data-candidate-filter placeholder="{{localize 'ACKS-HENCHMEN.candidate.filter'}}" />
    </div>
    <table class="candidates-table">
      <thead>
        <tr>
          <th data-sortable>{{localize "ACKS-HENCHMEN.candidate.name"}}</th>
          <th data-sortable>{{localize "ACKS-HENCHMEN.candidate.age"}}</th>
          <th data-sortable>{{localize "ACKS-HENCHMEN.candidate.culture"}}</th>
          <th data-sortable>{{localize "ACKS-HENCHMEN.candidate.identity"}}</th>
          <th data-sortable>{{localize "ACKS-HENCHMEN.candidate.wage"}}</th>
          <th data-sortable data-tooltip="{{localize 'ACKS-HENCHMEN.special.refusalsHint'}}">{{localize "ACKS-HENCHMEN.special.refusals"}}</th>
          <th data-sortable>{{localize "ACKS-HENCHMEN.candidate.statusHeader"}}</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {{#each henchmenRows}}
        <tr data-candidate-id="{{id}}" class="status-{{status}}">
          <td data-tooltip="{{appearanceTip}}">{{name}}</td>
          <td>{{age}}</td>
          <td>{{cultureLabel}}</td>
          <td>{{identityLine}}</td>
          <td>{{#if wageGp}}{{wageGp}} gp/{{wageUnit}}{{/if}}</td>
          <td>{{refusalCount}}</td>
          <td>{{statusLabel}}</td>
          <td class="row-actions">
            {{#if isAvailable}}
            <a data-action="recruit" data-tooltip="{{localize 'ACKS-HENCHMEN.candidate.recruit'}}"><i class="fas fa-handshake"></i></a>
            {{/if}}
            {{#if @root.isGM}}
            <a data-action="removeCandidate" data-tooltip="{{localize 'ACKS-HENCHMEN.candidate.remove'}}"><i class="fas fa-trash"></i></a>
            {{/if}}
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    {{else}}
    <p class="hint">{{localize "ACKS-HENCHMEN.candidate.none"}}</p>
    {{/if}}
  </section>

  {{!-- ------------------------- Mercenaries ------------------------- --}}
  <section class="tab location-tab {{tabs.mercenaries.cssClass}}" data-group="primary" data-tab="mercenaries">
    {{#if mercenaryRows.length}}
    <table class="candidates-table">
      <thead>
        <tr>
          <th data-sortable>{{localize "ACKS-HENCHMEN.candidate.troopType"}}</th>
          <th data-sortable>{{localize "ACKS-HENCHMEN.candidate.qty"}}</th>
          <th data-sortable>{{localize "ACKS-HENCHMEN.candidate.wage"}}</th>
          <th data-sortable>{{localize "ACKS-HENCHMEN.candidate.statusHeader"}}</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {{#each mercenaryRows}}
        <tr data-candidate-id="{{id}}" class="status-{{status}}">
          <td>{{name}}</td>
          <td>{{quantity}}</td>
          <td>{{#if wageGp}}{{wageGp}} gp/{{wageUnit}}{{/if}}</td>
          <td>{{statusLabel}}</td>
          <td class="row-actions">
            {{#if isAvailable}}
            <a data-action="recruit" data-tooltip="{{localize 'ACKS-HENCHMEN.candidate.recruit'}}"><i class="fas fa-handshake"></i></a>
            {{/if}}
            {{#if @root.isGM}}
            <a data-action="removeCandidate" data-tooltip="{{localize 'ACKS-HENCHMEN.candidate.remove'}}"><i class="fas fa-trash"></i></a>
            {{/if}}
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    {{else}}
    <p class="hint">{{localize "ACKS-HENCHMEN.candidate.none"}}</p>
    {{/if}}
  </section>

  {{!-- ------------------------- Specialists ------------------------- --}}
  <section class="tab location-tab {{tabs.specialists.cssClass}}" data-group="primary" data-tab="specialists">
    {{#if specialistRows.length}}
    <div class="candidate-filter">
      <i class="fas fa-magnifying-glass"></i>
      <input type="text" data-candidate-filter placeholder="{{localize 'ACKS-HENCHMEN.candidate.filter'}}" />
    </div>
    <table class="candidates-table">
      <thead>
        <tr>
          <th data-sortable>{{localize "ACKS-HENCHMEN.candidate.name"}}</th>
          <th data-sortable>{{localize "ACKS-HENCHMEN.candidate.age"}}</th>
          <th data-sortable>{{localize "ACKS-HENCHMEN.candidate.culture"}}</th>
          <th data-sortable>{{localize "ACKS-HENCHMEN.candidate.specialty"}}</th>
          <th data-sortable>{{localize "ACKS-HENCHMEN.candidate.wage"}}</th>
          <th data-sortable data-tooltip="{{localize 'ACKS-HENCHMEN.special.refusalsHint'}}">{{localize "ACKS-HENCHMEN.special.refusals"}}</th>
          <th data-sortable>{{localize "ACKS-HENCHMEN.candidate.statusHeader"}}</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {{#each specialistRows}}
        <tr data-candidate-id="{{id}}" class="status-{{status}}">
          <td data-tooltip="{{appearanceTip}}">{{name}}{{#if isAggregate}} ×{{quantity}}{{/if}}</td>
          <td>{{age}}</td>
          <td>{{cultureLabel}}</td>
          <td>{{identityLine}}</td>
          <td>{{#if wageGp}}{{wageGp}} gp/{{wageUnit}}{{/if}}</td>
          <td>{{refusalCount}}</td>
          <td>{{statusLabel}}</td>
          <td class="row-actions">
            {{#if isAvailable}}
            <a data-action="recruit" data-tooltip="{{localize 'ACKS-HENCHMEN.candidate.recruit'}}"><i class="fas fa-handshake"></i></a>
            {{/if}}
            {{#if @root.isGM}}
            <a data-action="removeCandidate" data-tooltip="{{localize 'ACKS-HENCHMEN.candidate.remove'}}"><i class="fas fa-trash"></i></a>
            {{/if}}
          </td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    {{else}}
    <p class="hint">{{localize "ACKS-HENCHMEN.candidate.none"}}</p>
    {{/if}}
  </section>

  {{#if isGM}}
  {{!-- ------------------------- GM settings ------------------------- --}}
  <section class="tab location-tab {{tabs.gmSettings.cssClass}}" data-group="primary" data-tab="gmSettings">
    <div class="grid-2">
      <div class="form-group">
        <label>{{localize "ACKS-HENCHMEN.location.region"}}</label>
        <input type="text" name="system.region" value="{{system.region}}" />
      </div>
      <div class="form-group">
        <label>{{localize "ACKS-HENCHMEN.location.urbanFamilies"}}</label>
        <input type="number" name="system.urbanFamilies" value="{{system.urbanFamilies}}" min="0" step="1" />
      </div>
      <div class="form-group">
        <label data-tooltip="{{localize 'ACKS-HENCHMEN.location.overrideHint'}}">{{localize "ACKS-HENCHMEN.location.override"}}</label>
        <select name="system.marketClassOverride">
          <option value="" {{#unless system.marketClassOverride}}selected{{/unless}}>{{localize "ACKS-HENCHMEN.location.noOverride"}}</option>
          <option value="1" {{#if (eq system.marketClassOverride 1)}}selected{{/if}}>I</option>
          <option value="2" {{#if (eq system.marketClassOverride 2)}}selected{{/if}}>II</option>
          <option value="3" {{#if (eq system.marketClassOverride 3)}}selected{{/if}}>III</option>
          <option value="4" {{#if (eq system.marketClassOverride 4)}}selected{{/if}}>IV</option>
          <option value="5" {{#if (eq system.marketClassOverride 5)}}selected{{/if}}>V</option>
          <option value="6" {{#if (eq system.marketClassOverride 6)}}selected{{/if}}>VI</option>
        </select>
      </div>
      <div class="form-group">
        <label data-tooltip="{{localize 'ACKS-HENCHMEN.location.alignmentHint'}}">{{localize "ACKS-HENCHMEN.location.alignment"}}</label>
        <select name="system.settlementAlignment">
          <option value="lawful" {{#if (eq system.settlementAlignment "lawful")}}selected{{/if}}>{{localize "ACKS-HENCHMEN.alignment.lawful"}}</option>
          <option value="neutral" {{#if (eq system.settlementAlignment "neutral")}}selected{{/if}}>{{localize "ACKS-HENCHMEN.alignment.neutral"}}</option>
          <option value="chaotic" {{#if (eq system.settlementAlignment "chaotic")}}selected{{/if}}>{{localize "ACKS-HENCHMEN.alignment.chaotic"}}</option>
        </select>
      </div>
      <div class="form-group">
        <label>{{localize "ACKS-HENCHMEN.location.rarityTable"}}</label>
        <select name="system.classRarityTableId">
          {{#each rarityVariants}}
          <option value="{{id}}" {{#if selected}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
      </div>
      <div class="form-group">
        <label data-tooltip="{{localize 'ACKS-HENCHMEN.location.desertHint'}}">{{localize "ACKS-HENCHMEN.location.desert"}}</label>
        <input type="checkbox" name="system.desertRealm" {{#if system.desertRealm}}checked{{/if}} />
      </div>
      <div class="form-group">
        <label data-tooltip="{{localize 'ACKS-HENCHMEN.location.compositeHint'}}">{{localize "ACKS-HENCHMEN.location.composite"}}</label>
        <select name="system.compositeVariant">
          <option value="composite" {{#if (eq system.compositeVariant "composite")}}selected{{/if}}>{{localize "ACKS-HENCHMEN.troop.compositeBowman"}}</option>
          <option value="longbow" {{#if (eq system.compositeVariant "longbow")}}selected{{/if}}>{{localize "ACKS-HENCHMEN.troop.longbowman"}}</option>
        </select>
      </div>
    </div>
    <div class="demographics-block" data-tooltip="{{localize 'ACKS-HENCHMEN.location.mixDropHint'}}">
      <label class="block-label" data-tooltip="{{localize 'ACKS-HENCHMEN.location.demographicsHint'}}">
        {{localize "ACKS-HENCHMEN.location.demographics"}}
        <a class="inline-add" data-action="addDemographic"><i class="fas fa-plus"></i></a>
        <a class="inline-add" data-action="exportDemographics" data-tooltip="{{localize 'ACKS-HENCHMEN.location.mixExport'}}"><i class="fas fa-file-export"></i></a>
      </label>
      {{#each demographics}}
      <div class="demographic-row" data-demographic-index="{{index}}">
        <select name="system.demographics.{{index}}.culture">
          {{#each @root.cultureOptions}}
          <option value="{{id}}" {{#if (eq id ../culture)}}selected{{/if}}>{{label}}</option>
          {{/each}}
        </select>
        <input type="number" name="system.demographics.{{index}}.weight" value="{{weight}}" min="0" step="1" data-tooltip="{{localize 'ACKS-HENCHMEN.location.weight'}}" />
        <a data-action="removeDemographic"><i class="fas fa-trash"></i></a>
      </div>
      {{else}}
      <p class="hint">{{localize "ACKS-HENCHMEN.location.demographicsEmpty"}}</p>
      {{/each}}
    </div>

    <details class="section">
      <summary>
        {{localize "ACKS-HENCHMEN.location.slander"}} ({{slander.length}})
        <button type="button" class="inline-add" data-action="addSlander"><i class="fas fa-plus"></i></button>
      </summary>
      <p class="hint">{{localize "ACKS-HENCHMEN.location.slanderHint"}}</p>
      {{#each slander}}
      <div class="slander-row" data-slander-index="{{index}}">
        <input type="text" name="system.slander.{{index}}.partyKey" value="{{partyKey}}" placeholder="{{localize 'ACKS-HENCHMEN.location.slanderParty'}}" />
        <input type="text" name="system.slander.{{index}}.npcName" value="{{npcName}}" placeholder="{{localize 'ACKS-HENCHMEN.location.slanderNpc'}}" />
        <input type="text" name="system.slander.{{index}}.note" value="{{note}}" placeholder="{{localize 'ACKS-HENCHMEN.location.slanderNote'}}" />
        <a data-action="removeSlander"><i class="fas fa-trash"></i></a>
      </div>
      {{/each}}
    </details>

    <details class="section">
      <summary>{{localize "ACKS-HENCHMEN.location.notesHeader"}}</summary>
      <textarea name="system.notes" rows="4">{{system.notes}}</textarea>
    </details>
  </section>

  {{!-- ------------------------- GM view ------------------------- --}}
  <section class="tab location-tab {{tabs.gmView.cssClass}}" data-group="primary" data-tab="gmView">
    <p class="hint">{{localize "ACKS-HENCHMEN.market.hint"}}</p>
    {{#if market.length}}
    <table class="market-table">
      <thead>
        <tr>
          <th>{{localize "ACKS-HENCHMEN.market.segment"}}</th>
          <th data-tooltip="{{localize 'ACKS-HENCHMEN.posting.weekHint'}}">{{localize "ACKS-HENCHMEN.posting.week"}}</th>
          <th data-tooltip="{{localize 'ACKS-HENCHMEN.posting.poolHint'}}">{{localize "ACKS-HENCHMEN.posting.pool"}}</th>
          <th>{{localize "ACKS-HENCHMEN.market.arrived"}}</th>
          <th>{{localize "ACKS-HENCHMEN.market.hired"}}</th>
        </tr>
      </thead>
      <tbody>
        {{#each market}}
        <tr>
          <td data-tooltip="{{detail}}">{{label}}</td>
          <td>{{week}}</td>
          <td>{{total}}</td>
          <td>{{arrived}}{{#if pending}} <span class="hint">(+{{pending}})</span>{{/if}}</td>
          <td>{{hired}}</td>
        </tr>
        {{/each}}
      </tbody>
    </table>
    {{else}}
    <p class="hint">{{localize "ACKS-HENCHMEN.market.empty"}}</p>
    {{/if}}

    <details class="section">
      <summary>{{localize "ACKS-HENCHMEN.location.ledger"}} ({{ledgerTotal}} gp)</summary>
      <table class="ledger-table">
        <tbody>
          {{#each ledger}}
          <tr><td>{{gp}} gp</td><td>{{postingId}}</td></tr>
          {{/each}}
        </tbody>
      </table>
    </details>
  </section>
  {{/if}}
</div>
